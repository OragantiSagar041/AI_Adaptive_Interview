# Public backend URL. Docker Compose defaults to the current host on port 8000.
VITE_API_BASE_URL=

# Self-host these versioned MediaPipe assets in production to remove CDN dependency.
VITE_MEDIAPIPE_WASM_URL=
VITE_FACE_LANDMARKER_MODEL_URL=
VITE_OBJECT_DETECTOR_MODEL_URL=

# Production WebRTC relay. Required for corporate networks and symmetric NAT.
VITE_TURN_URLS=turn:turn.example.com:3478,turns:turn.example.com:5349
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
