# API Keys for LLM Generation
OPENROUTER_API_KEY=your_openrouter_api_key_here
GROQ_API_KEY=your_groq_api_key_here


# Database
MONGO_URI=mongodb+srv:/username:password@cluster.mongodb.net/?appName=Cluster0
REDIS_URL=redis://localhost:6379/0
ENV=local
# Enable only when a trusted reverse proxy overwrites X-Real-IP/X-Forwarded-For.
TRUST_PROXY_HEADERS=false
CORS_ORIGIN_REGEX=
FRONTEND_URL=http://localhost:5173

# Cloudinary (Media Storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Brevo (Email Sending)
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=your_sender_email@domain.com
BREVO_SENDER_NAME=Your Name

# Payments (Razorpay/Stripe)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
STRIPE_SECRET_KEY=your_stripe_secret
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Authentication
JWT_SECRET_KEY=super-secret-default-key-for-local-dev

# Interview media
CARTESIA_API_KEY=your_cartesia_api_key
CARTESIA_VOICE_ID=your_default_voice_id
RECORDING_RETENTION_DAYS=3
